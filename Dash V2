// ── HIGHWAY ROW ───────────────────────────────────────────────────────────────
function HwyRow({ h }) {
  // Pro-rata values
  const saPct  = HANDED_KM / TOTAL_KM;          // 15.62/30.83
  const hfPct  = AVAIL_KM / TOTAL_KM;           // 12.85/30.83
  const sa_cr  = h.ca_cr * saPct;
  const hf_cr  = h.ca_cr * hfPct;

  // Progress % against hindrance-free value
  const certPctHF = hf_cr > 0 ? Math.min(100, (h.cert_cr / hf_cr) * 100) : 0;
  const wipPctHF  = hf_cr > 0 ? Math.min(100 - certPctHF, (h.wip_cr / hf_cr) * 100) : 0;
  const totalPctHF = certPctHF + wipPctHF;

  const fmt = (v) => v >= 1000 ? v.toLocaleString("en-IN",{maximumFractionDigits:0}) : v.toLocaleString("en-IN",{maximumFractionDigits:3});
  const hasProgress = h.cert_cr > 0 || h.wip_cr > 0;
  const borderCol = totalPctHF > 50 ? "#059669" : totalPctHF > 0 ? "#D97706" : "#E2E8F0";

  return (
    <div style={{ border:`1px solid #E2E8F0`, borderLeft:`4px solid ${borderCol}`,
      borderRadius:8, padding:"14px 16px", marginBottom:10, background:"white" }}>

      {/* Title row */}
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:10 }}>
        <div>
          <span style={{ fontWeight:800, fontSize:13, color:"#0F2942" }}>{h.lbl}</span>
          <span style={{ fontSize:10, color:"#64748B", marginLeft:8 }}>
            {fmt(h.scope)} {h.unit} · Wt: {h.wt}%
          </span>
        </div>
        {hasProgress ? (
          <span style={{ fontSize:11, fontWeight:700, color:"#059669", background:"#D1FAE5",
            padding:"3px 10px", borderRadius:8 }}>{p2(totalPctHF)}% of HF value</span>
        ) : (
          <span style={{ fontSize:11, fontWeight:600, color:"#94A3B8", background:"#F8FAFC",
            padding:"3px 10px", borderRadius:8 }}>Yet to Start</span>
        )}
      </div>

      {/* Value comparison: CA → SA → HF → Certified → WIP */}
      <div style={{ display:"grid", gridTemplateColumns:"repeat(5,1fr)", gap:6, marginBottom:10 }}>
        {[
          ["CA Value",     `₹${p2(h.ca_cr)} Cr`, "#374151","#F8FAFC"],
          ["SA (15.62 Km)",`₹${p2(sa_cr)} Cr`,   "#0369A1","#EFF6FF"],
          ["HF (12.85 Km)",`₹${p2(hf_cr)} Cr`,   "#7C3AED","#F5F3FF"],
          ["Certified",    h.cert_cr > 0 ? `₹${p2(h.cert_cr)} Cr` : "—", "#059669","#D1FAE5"],
          ["WIP",          h.wip_cr > 0 ? `₹${p2(h.wip_cr)} Cr` : "—",  "#D97706","#FEF3C7"],
        ].map(([l,v,c,b])=>(
          <div key={l} style={{ background:b, borderRadius:6, padding:"6px 8px" }}>
            <div style={{ fontSize:8.5, fontWeight:700, color:c, textTransform:"uppercase", marginBottom:1 }}>{l}</div>
            <div style={{ fontSize:14, fontWeight:800, color:c }}>{v}</div>
          </div>
        ))}
      </div>

      {/* Progress bar against HF value */}
      <div style={{ fontSize:10, fontWeight:600, color:"#64748B", marginBottom:3 }}>
        Progress vs Hindrance-Free Value (₹{p2(hf_cr)} Cr)
      </div>
      <div style={{ background:"#E2E8F0", borderRadius:5, height:20, position:"relative", overflow:"hidden" }}>
        {certPctHF > 0 && <div style={{ position:"absolute", left:0, top:0, height:"100%", width:`${certPctHF}%`, background:"#10B981" }}/>}
        {wipPctHF > 0 && <div style={{ position:"absolute", left:`${certPctHF}%`, top:0, height:"100%", width:`${wipPctHF}%`, background:"#FBBF24" }}/>}
        <span style={{ position:"absolute", width:"100%", textAlign:"center",
          fontSize:9.5, fontWeight:800, color:"#1E293B", lineHeight:"20px" }}>
          {hasProgress
            ? `${certPctHF > 0 ? p2(certPctHF)+'% certified' : ''}${certPctHF > 0 && wipPctHF > 0 ? ' + ' : ''}${wipPctHF > 0 ? p2(wipPctHF)+'% WIP' : ''}`
            : "No progress yet"
          }
        </span>
      </div>

      {/* Qty row if there's progress */}
      {hasProgress && (
        <div style={{ display:"flex", gap:16, marginTop:6, fontSize:10, color:"#64748B" }}>
          {h.cert_qty > 0 && <span>Certified: <b style={{color:"#059669"}}>{fmt(h.cert_qty)} {h.unit}</b></span>}
          {h.wip_qty > 0 && <span>WIP: <b style={{color:"#D97706"}}>{fmt(h.wip_qty)} {h.unit}</b></span>}
        </div>
      )}
    </div>
  );
