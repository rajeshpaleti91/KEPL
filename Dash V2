                  <div style={{ background:"#0F172A", borderRadius:12, padding:"20px 24px", textAlign:"center", minWidth:160 }}>
                    <div style={{ fontSize:10, color:"#94A3B8", fontWeight:700, textTransform:"uppercase", marginBottom:4 }}>Overall Health Score</div>
                    <div style={{ fontSize:42, fontWeight:800, color: overallPct > 60 ? "#10B981" : overallPct > 40 ? "#FBBF24" : "#EF4444" }}>
                      {overallScore}/{overallMax}
                    </div>
                    <div style={{ fontSize:11, color:"#94A3B8", marginTop:4 }}>{p2(overallPct)}% — {overallPct > 60 ? "Healthy" : overallPct > 40 ? "At Risk" : "Critical"}</div>
                  </div>
                  <div style={{ flex:1 }}>
                    <div style={{ fontSize:12, fontWeight:700, color:"#0F2942", marginBottom:8 }}>Dimension Summary</div>
                    <div style={{ display:"flex", gap:6, flexWrap:"wrap" }}>
                      {dimensions.map(d => (
                        <span key={d.dim} style={{ background:statusBg(d.status), color:statusColor(d.status),
                          padding:"4px 10px", borderRadius:6, fontSize:10, fontWeight:700, border:`1px solid ${statusColor(d.status)}30` }}>
                          {d.dim}: {d.score}/{d.max}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>

                {/* Dimension Cards */}
                <div style={{ display:"grid", gridTemplateColumns:"repeat(auto-fill, minmax(420px, 1fr))", gap:12 }}>
                  {dimensions.map(d => (
                    <div key={d.dim} style={{ background:"white", borderRadius:10, padding:"16px 18px",
                      borderLeft:`5px solid ${statusColor(d.status)}`, boxShadow:"0 1px 4px #0000000a" }}>
                      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:8 }}>
                        <span style={{ fontWeight:800, fontSize:13, color:"#0F2942" }}>{d.dim}</span>
                        <span style={{ background:statusBg(d.status), color:statusColor(d.status),
                          padding:"3px 10px", borderRadius:6, fontSize:10, fontWeight:800 }}>{d.status} — {d.score}/{d.max}</span>
                      </div>
                      {/* Score bar */}
                      <div style={{ background:"#E2E8F0", borderRadius:4, height:8, marginBottom:10, overflow:"hidden" }}>
                        <div style={{ width:`${(d.score/d.max)*100}%`, height:"100%", background:statusColor(d.status), borderRadius:4 }}/>
                      </div>
                      {/* Finding */}
                      <div style={{ fontSize:10.5, color:"#374151", marginBottom:6 }}>
                        <span style={{ fontWeight:700, color:"#64748B" }}>Finding: </span>{d.finding}
                      </div>
                      {/* Action */}
                      <div style={{ fontSize:10.5, color:"#065F46", marginBottom:6, background:"#F0FDF4", padding:"6px 10px", borderRadius:4 }}>
                        <span style={{ fontWeight:700 }}>Action: </span>{d.action}
                      </div>
                      {/* Lean Insight */}
                      <div style={{ fontSize:10, color:"#7C3AED", fontStyle:"italic", background:"#F5F3FF", padding:"5px 10px", borderRadius:4 }}>
                        {d.lean}
                      </div>
                    </div>
                  ))}
                </div>
              </>);
            })()}
          </Box>

          {/* Bottleneck Theory of Constraints */}
          <Box>
            <BHead>THEORY OF CONSTRAINTS — BOTTLENECK ANALYSIS (Goldratt)</BHead>
            <div style={{ fontSize:10.5, color:"#64748B", marginBottom:12 }}>
              Identify the system constraint, exploit it, subordinate everything else to it, elevate, repeat.
            </div>
            {[
              { step:"1. IDENTIFY", constraint:"Land Availability (12.85 Km of 30.83 Km)", col:"#DC2626",
                detail:"The binding constraint is land. All other resources — equipment, materials, labour, finance — are subordinate to this single bottleneck." },
              { step:"2. EXPLOIT", constraint:"Maximize throughput on available 12.85 Km", col:"#D97706",
                detail:"Every available metre must be under active construction. No idle work front should exist within the 12.85 Km. Deploy multiple crews on parallel activities (earthwork + structures + utilities simultaneously)." },
              { step:"3. SUBORDINATE", constraint:"Align all resources to the constraint", col:"#0369A1",
                detail:"Material procurement, equipment positioning, crew scheduling, and billing cycles should all be synchronized to the available work front — not the full 30.83 Km scope." },
              { step:"4. ELEVATE", constraint:"Aggressively pursue land release", col:"#059669",
                detail:"DRB proceedings, NHAI escalation, SA Clause 4.2 enforcement, court matter resolution, Bodduraithanda relocation — every avenue to release more land must be pursued simultaneously." },
              { step:"5. REPEAT", constraint:"Re-assess when new land is released", col:"#7C3AED",
                detail:"As each constraint is elevated (land released, MJB decided, pavement approved), the next bottleneck becomes visible. Re-apply the cycle." },
            ].map(s => (
              <div key={s.step} style={{ display:"flex", gap:14, marginBottom:10, padding:"12px 14px",
                background:"#F8FAFC", borderRadius:8, borderLeft:`4px solid ${s.col}` }}>
                <div style={{ minWidth:100 }}>
                  <div style={{ fontSize:10, fontWeight:800, color:s.col }}>{s.step}</div>
                  <div style={{ fontSize:11, fontWeight:700, color:"#0F2942", marginTop:2 }}>{s.constraint}</div>
                </div>
                <div style={{ fontSize:11, color:"#374151", lineHeight:1.5 }}>{s.detail}</div>
              </div>
            ))}
          </Box>

          {/* 5 Whys */}
          <Box>
            <BHead>5 WHYS ROOT CAUSE — WHY IS PROGRESS AT 11.31%?</BHead>
            {[
              { why:"Why is progress only 11.31%?", ans:"Because only 12.85 Km (41.7%) of the 30.83 Km alignment is available for construction." },
              { why:"Why is only 12.85 Km available?", ans:"Because 15.21 Km was never handed over, 2.02 Km is under High Court stay, and 0.75 Km has payment/access issues." },
              { why:"Why was 15.21 Km not handed over?", ans:"Because NHAI has not completed land acquisition for the balance stretch. SA Clause 4.2 deadline (07.01.2026) has been breached." },
              { why:"Why is the existing 12.85 Km not fully utilized?", ans:"Because pavement design is rejected (blocking earthwork certification), MJB decision blocks 1 Km, and TCS rework consumes resources on already-executed sections." },
              { why:"Why are decisions on pavement/MJB pending?", ans:"Because the Authority has not provided clear directions despite multiple submissions. These are now referred to DRB." },
            ].map((w,i) => (
              <div key={i} style={{ display:"flex", gap:12, marginBottom:8 }}>
                <div style={{ minWidth:28, height:28, borderRadius:14, background:i===4?"#DC2626":"#1E3A5F",
                  display:"flex", alignItems:"center", justifyContent:"center" }}>
                  <span style={{ color:"white", fontSize:12, fontWeight:800 }}>{i+1}</span>
                </div>
                <div style={{ flex:1 }}>
                  <div style={{ fontSize:11, fontWeight:700, color:"#DC2626", marginBottom:2 }}>{w.why}</div>
                  <div style={{ fontSize:11, color:"#374151" }}>{w.ans}</div>
                </div>
              </div>
            ))}
            <div style={{ marginTop:12, padding:"10px 14px", background:"#FEE2E2", borderRadius:8, borderLeft:"4px solid #DC2626" }}>
              <div style={{ fontSize:11, fontWeight:700, color:"#991B1B" }}>
                ROOT CAUSE: The Authority has not fulfilled its land handover obligations under the Concession Agreement and Settlement Agreement,
                and has not provided timely decisions on design matters. The Concessionaire's execution capacity is not the constraint.
              </div>
            </div>
          </Box>
        </>}

        {/* ═══════════════ RISK & DECISIONS ═══════════════════════════════════ */}
        {tab === "risk" && (
          <Box>
            <BHead>RISK & DECISIONS — Coming Soon</BHead>
            <div style={{ textAlign:"center", padding:"60px 0" }}>
              <div style={{ fontSize:48, opacity:0.15, marginBottom:16 }}>⚡</div>
              <div style={{ fontSize:16, fontWeight:600, color:"#94A3B8" }}>Risk Register & Decision Log</div>
              <div style={{ fontSize:12, color:"#CBD5E1", marginTop:8 }}>This tab will track active risks, mitigation actions, pending decisions, and resolution timelines.</div>
            </div>
          </Box>
        )}

      </div>

      {/* FOOTER */}
      <div style={{ background:"#0F172A", padding:"9px 22px", display:"flex",
        justifyContent:"space-between", flexWrap:"wrap", gap:4, fontSize:10, color:"#475569" }}>
        <span>KEPL · NH-163G Pkg-III · Ch. 189.650–220.480 Km · Khammam, Telangana</span>
        <span>CA: 18.12.2023 · Settlement: 10.07.2025 · JMS: 25.01.2025</span>
        <span>Report: 09 March 2026 · Submitted to: IE (LASA/EKAM) & NHAI PIU-Khammam-II</span>
      </div>
    </div>
  );
}


const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(<App />);
  </script>
</body>
