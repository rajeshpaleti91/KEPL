// ── HELPERS ──────────────────────────────────────────────────────────────────
const p2 = (n) => n.toFixed(2);
const pct = (a,b) => b>0 ? Math.min(100,(a/b)*100) : 0;

const stColor = (p) => {
  if (p <= 0)  return ["#EF4444","#FEF2F2","#991B1B","Not Started"];
  if (p < 15)  return ["#F59E0B","#FFFBEB","#92400E","Initiated"];
  if (p < 50)  return ["#3B82F6","#EFF6FF","#1D4ED8","In Progress"];
  if (p < 85)  return ["#10B981","#ECFDF5","#065F46","Advanced"];
  return              ["#059669","#D1FAE5","#064E3B","Near Complete"];
};

const structStatus = (lhs, rhs) => {
  if (!lhs && !rhs) return { bg:"#FEF2F2", tc:"#991B1B", lbl:"Yet to Start" };
  const s = ((lhs||"")+" "+(rhs||"")).toLowerCase();
  if ((s.includes("complete") || s.includes("completed")) && !s.includes("progress") && !s.includes("staging") && !s.includes("laying"))
    return { bg:"#D1FAE5", tc:"#065F46", lbl:"Completed" };
  return { bg:"#FEF9C3", tc:"#92400E", lbl:"WIP" };
};

// ── REUSABLE UI ───────────────────────────────────────────────────────────────
function Box({ children, style={} }) {
  return <div style={{ background:"white", borderRadius:12, padding:"18px 20px",
    boxShadow:"0 1px 8px #0000000d", marginBottom:16, ...style }}>{children}</div>;
}
function BHead({ children }) {
  return <div style={{ fontWeight:800, fontSize:13, color:"#0F2942", borderBottom:"2px solid #DBEAFE",
    paddingBottom:8, marginBottom:14 }}>{children}</div>;
}
function KPI({ label, value, sub, accent="#1E40AF", bg="#EFF6FF" }) {
  return (
    <div style={{ background:bg, borderLeft:`4px solid ${accent}`, borderRadius:10,
      padding:"14px 18px", flex:"1 1 180px", minWidth:160 }}>
      <div style={{ fontSize:10, fontWeight:700, color:"#64748B", textTransform:"uppercase",
        letterSpacing:.8, marginBottom:4 }}>{label}</div>
      <div style={{ fontSize:22, fontWeight:800, color:accent, lineHeight:1.1 }}>{value}</div>
      {sub && <div style={{ fontSize:10.5, color:"#64748B", marginTop:4 }}>{sub}</div>}
    </div>
  );
}

function Bar({ comp, wip=0, total=100, showPct=true, h=20 }) {
  const cp = Math.min(100, pct(comp, total));
  const wp = Math.min(100-cp, pct(wip, total));
  return (
    <div style={{ background:"#E2E8F0", borderRadius:6, height:h, position:"relative", overflow:"hidden" }}>
      {cp>0 && <div style={{ position:"absolute", left:0, top:0, height:"100%", width:`${cp}%`, background:"#10B981" }}/>}
      {wp>0 && <div style={{ position:"absolute", left:`${cp}%`, top:0, height:"100%", width:`${wp}%`, background:"#FBBF24" }}/>}
      {showPct && (
        <span style={{ position:"absolute", width:"100%", textAlign:"center",
          fontSize:h>16?10:9, fontWeight:800, color:"#1E293B", lineHeight:`${h}px` }}>
          {cp>0||wp>0 ? `${cp.toFixed(1)}% done${wp>0?` + ${wp.toFixed(1)}% WIP`:""}` : "No Progress"}
        </span>
      )}
    </div>
  );
}

